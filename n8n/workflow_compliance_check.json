{
  "name": "compliance-check",
  "nodes": [
    {
      "id": "trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [200, 300],
      "parameters": {
        "path": "compliance-check",
        "responseMode": "lastNode",
        "httpMethod": "POST"
      }
    },
    {
      "id": "check",
      "name": "Compliance Gate",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300],
      "parameters": {
        "method": "POST",
        "url": "http://88.218.121.108:8080/compliance/check",
        "bodyContentType": "json",
        "jsonBody": "={{ JSON.stringify({text: $json.text, vertical: $json.vertical || 'nutra', geo: $json.geo || 'PL'}) }}",
        "options": {"timeout": 10000}
      }
    },
    {
      "id": "gate",
      "name": "Verdict block?",
      "type": "n8n-nodes-base.if",
      "position": [720, 300],
      "parameters": {
        "conditions": {
          "string": [{"value1": "={{ $json.verdict }}", "operation": "notEqual", "value2": "block"}]
        }
      }
    },
    {
      "id": "pass",
      "name": "Pass",
      "type": "n8n-nodes-base.noOp",
      "position": [980, 200],
      "parameters": {}
    },
    {
      "id": "alert",
      "name": "Telegram — Block",
      "type": "n8n-nodes-base.telegram",
      "position": [980, 420],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_ALERT_CHAT_ID }}",
        "text": "🚫 *Compliance BLOCK*\nVertical: `{{ $('Compliance Gate').item.json.vertical }}`\nGeo: `{{ $('Compliance Gate').item.json.geo }}`\nReason: {{ $('Compliance Gate').item.json.reason }}",
        "additionalFields": {"parse_mode": "Markdown"}
      }
    }
  ],
  "connections": {
    "Webhook":          {"main": [[{"node": "Compliance Gate"}]]},
    "Compliance Gate":  {"main": [[{"node": "Verdict block?"}]]},
    "Verdict block?":   {"main": [[{"node": "Pass"}], [{"node": "Telegram — Block"}]]}
  },
  "settings": {"timezone": "Europe/Moscow"}
}
