{
  "name": "keitaro-postback",
  "nodes": [
    {
      "id": "trigger",
      "name": "Postback Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [200, 300],
      "parameters": {
        "path": "keitaro-postback",
        "responseMode": "lastNode",
        "httpMethod": "POST"
      }
    },
    {
      "id": "send",
      "name": "Send to UBT OS",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300],
      "parameters": {
        "method": "POST",
        "url": "http://88.218.121.108:8080/keitaro/postback",
        "bodyContentType": "json",
        "jsonBody": "={{ JSON.stringify({keitaro_click_id: $json.click_id, offer_id: $json.offer_id, revenue_usd: $json.revenue || 0, payout_usd: $json.payout || 0, conversion_type: $json.conversion_type || 'lead', partner: $json.partner || '', geo: $json.geo || ''}) }}",
        "options": {"timeout": 15000}
      }
    },
    {
      "id": "gate",
      "name": "Saved ok?",
      "type": "n8n-nodes-base.if",
      "position": [720, 300],
      "parameters": {
        "conditions": {
          "boolean": [{"value1": "={{ $json.ok }}", "operation": "equal", "value2": true}]
        }
      }
    },
    {
      "id": "alert_ok",
      "name": "Telegram — Conversion",
      "type": "n8n-nodes-base.telegram",
      "position": [980, 180],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_ALERT_CHAT_ID }}",
        "text": "💰 *Конверсия*\nOffer: `{{ $('Send to UBT OS').item.json.offer_id || '—' }}`\nPayout: ${{ $json.payout || 0 }}\nWithin window: {{ $json.within_window }}",
        "additionalFields": {"parse_mode": "Markdown"}
      }
    },
    {
      "id": "alert_err",
      "name": "Telegram — Error",
      "type": "n8n-nodes-base.telegram",
      "position": [980, 420],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_ALERT_CHAT_ID }}",
        "text": "⚠️ *Keitaro postback error*\nclick_id: `{{ $('Postback Webhook').item.json.click_id }}`\nResponse: {{ JSON.stringify($json) }}",
        "additionalFields": {"parse_mode": "Markdown"}
      }
    }
  ],
  "connections": {
    "Postback Webhook": {"main": [[{"node": "Send to UBT OS"}]]},
    "Send to UBT OS":   {"main": [[{"node": "Saved ok?"}]]},
    "Saved ok?":        {"main": [[{"node": "Telegram — Conversion"}], [{"node": "Telegram — Error"}]]}
  },
  "settings": {"timezone": "Europe/Moscow"}
}
