{
  "name": "knowledge-synthesizer",
  "nodes": [
    {
      "id": "trigger_daily",
      "name": "Ежедневно 23:45",
      "type": "n8n-nodes-base.cron",
      "position": [200, 280],
      "parameters": {
        "rule": {"interval": [{"field": "cronExpression", "expression": "45 23 * * *"}]}
      }
    },
    {
      "id": "trigger_weekly",
      "name": "Воскресенье 22:00",
      "type": "n8n-nodes-base.cron",
      "position": [200, 420],
      "parameters": {
        "rule": {"interval": [{"field": "cronExpression", "expression": "0 22 * * 0"}]}
      }
    },
    {
      "id": "set_mode_daily",
      "name": "Mode: daily",
      "type": "n8n-nodes-base.set",
      "position": [400, 280],
      "parameters": {
        "values": {"string": [{"name": "mode", "value": "daily"}]}
      }
    },
    {
      "id": "set_mode_weekly",
      "name": "Mode: weekly",
      "type": "n8n-nodes-base.set",
      "position": [400, 420],
      "parameters": {
        "values": {"string": [{"name": "mode", "value": "weekly"}]}
      }
    },
    {
      "id": "lock",
      "name": "FIX#3 — Lock",
      "type": "n8n-nodes-base.code",
      "position": [600, 350],
      "parameters": {
        "jsCode": "const mode=$input.first().json.mode;\nconst KEY=`pipeline_lock:knowledge-${mode}`;\nconst TOKEN=`ks-${Date.now()}`;\nconst ok=await $redis.set(KEY,TOKEN,'EX',3600,'NX');\nif(!ok) return [{json:{status:'skipped'}}];\n$execution.customData.set('lk',KEY);\n$execution.customData.set('lt',TOKEN);\nreturn [{json:{status:'acquired',mode}}];"
      }
    },
    {
      "id": "gate",
      "name": "IF acquired",
      "type": "n8n-nodes-base.if",
      "position": [800, 350],
      "parameters": {
        "conditions": {
          "string": [{"value1":"={{ $json.status }}","value2":"acquired","operation":"equal"}]
        }
      }
    },
    {
      "id": "run_synthesis",
      "name": "Запустить синтез",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1020, 260],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.AGENTS_WEBHOOK }}/knowledge/synthesize",
        "options": {"timeout": 180000},
        "bodyContentType": "json",
        "body": {"mode": "={{ $json.mode }}"}
      }
    },
    {
      "id": "write_obsidian",
      "name": "Записать в Obsidian",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1240, 200],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.AGENTS_WEBHOOK }}/obsidian/write",
        "bodyContentType": "json",
        "body": {
          "path":    "={{ $json.obsidian_path }}",
          "content": "={{ $json.obsidian_md }}",
          "append":  false
        }
      }
    },
    {
      "id": "append_learnings",
      "name": "Append → learnings-log",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1240, 320],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.AGENTS_WEBHOOK }}/obsidian/append",
        "bodyContentType": "json",
        "body": {
          "path":    "50 Resources/knowledge/learnings-log.md",
          "content": "\n\n---\n**{{ new Date().toISOString().slice(0,10) }}**\n={{ $json.what_worked?.[0] || '' }}"
        }
      }
    },
    {
      "id": "telegram",
      "name": "Telegram — Дайджест",
      "type": "n8n-nodes-base.telegram",
      "position": [1240, 440],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $env.TELEGRAM_ALERT_CHAT_ID }}",
        "text": "={{ $json.telegram_msg }}",
        "additionalFields": {"parse_mode": "Markdown"}
      }
    },
    {
      "id": "release",
      "name": "Release Lock",
      "type": "n8n-nodes-base.code",
      "position": [1460, 320],
      "parameters": {
        "jsCode": "const k=$execution.customData.get('lk'),t=$execution.customData.get('lt');\nif(k&&t){const lua=`if redis.call('get',KEYS[1])==ARGV[1] then return redis.call('del',KEYS[1]) else return 0 end`;await $redis.eval(lua,1,k,t);}\nreturn [{json:{done:true}}];"
      }
    },
    {"id":"skip","name":"Skip","type":"n8n-nodes-base.noOp","position":[800,480]}
  ],
  "connections": {
    "Ежедневно 23:45":   {"main":[[{"node":"Mode: daily"}]]},
    "Воскресенье 22:00": {"main":[[{"node":"Mode: weekly"}]]},
    "Mode: daily":       {"main":[[{"node":"FIX#3 — Lock"}]]},
    "Mode: weekly":      {"main":[[{"node":"FIX#3 — Lock"}]]},
    "FIX#3 — Lock":      {"main":[[{"node":"IF acquired"}]]},
    "IF acquired":       {"main":[[{"node":"Skip"}],[{"node":"Запустить синтез"}]]},
    "Запустить синтез":  {"main":[[{"node":"Записать в Obsidian"}]]},
    "Записать в Obsidian":   {"main":[[{"node":"Append → learnings-log"}]]},
    "Append → learnings-log":{"main":[[{"node":"Telegram — Дайджест"}]]},
    "Telegram — Дайджест":   {"main":[[{"node":"Release Lock"}]]}
  },
  "settings": {"errorWorkflow":"error-handler","timezone":"Europe/Moscow"}
}
