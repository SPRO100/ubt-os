# ═══════════════════════════════════════════════════════════════════════
# UBT OS — шаблон переменных окружения
# Скопируй в .env и заполни:  cp .env.template .env
# Файл .env в .gitignore — секреты НЕ коммитятся.
# ═══════════════════════════════════════════════════════════════════════

# ── ОБЯЗАТЕЛЬНЫЕ ДЛЯ СТАРТА ─────────────────────────────────────────────
ANTHROPIC_API_KEY=            # Claude API — https://console.anthropic.com
SUPABASE_URL=                 # https://<project>.supabase.co
SUPABASE_SERVICE_KEY=         # service_role key (только сервер, НЕ фронт)
REDIS_URL=                    # redis://default:<pass>@<host>:<port>  (Upstash)

# ── БЕЗОПАСНОСТЬ ────────────────────────────────────────────────────────
WEBHOOK_SECRET=               # HMAC-секрет для вебхуков n8n (X-Webhook-Signature)
AGENTS_API_TOKEN=             # Bearer-токен dashboard → /agents/run, /orchestrator/chat
CORS_ALLOW_ORIGIN=*           # В проде укажи домен dashboard, напр. https://app.example.com
AGENTS_PORT=8080              # Порт HTTP-сервера агентов
AGENTS_HOST=0.0.0.0           # За nginx можно ограничить до 127.0.0.1

# ── ПУБЛИКАЦИЯ (A26 Publer) ─────────────────────────────────────────────
PUBLER_API_KEY=               # https://app.publer.io ($12/мес)
PUBLER_TIKTOK_PROFILE_IDS=    # id1,id2
PUBLER_FACEBOOK_PROFILE_IDS=  # id1,id2
PUBLER_INSTAGRAM_PROFILE_IDS= # id1,id2
PUBLER_PINTEREST_PROFILE_IDS= # id1,id2  (опционально)
PUBLER_PINTEREST_BOARD_IDS=   # board1,board2  (опционально)

# ── МЕДИА-ГЕНЕРАЦИЯ (A30 Higgsfield) ───────────────────────────────────
HIGGSFIELD_API_KEY=           # https://higgsfield.ai
HIGGSFIELD_API_URL=           # опционально, override базового URL
HIGGSFIELD_MODEL=marketing_studio_video  # модель из каталога MCP

# ── ВИДЕО-ПРОВАЙДЕРЫ (переключатель генерации) ─────────────────────────
# Цепочка fallback воркера; per-запрос переопределяется полем "provider".
#   stock — бесплатно (Pexels+edge-tts+ffmpeg) · fal — ~$0.05/сек (Wan 2.5)
#   higgsfield — кредиты Higgsfield
VIDEO_PROVIDER_CHAIN=stock,fal,higgsfield
PEXELS_API_KEY=               # бесплатно: https://www.pexels.com/api/
FAL_KEY=                      # https://fal.ai/dashboard/keys
FAL_VIDEO_MODEL=fal-ai/wan-25-preview/text-to-video

# ── TTS: бесплатные голоса edge-tts (без ключа) ─────────────────────────
EDGE_TTS_VOICE_RU=ru-RU-DmitryNeural
EDGE_TTS_VOICE_EN=en-US-ChristopherNeural

# ── СУБТИТРЫ (A34 caption_agent) ────────────────────────────────────────
DEEPGRAM_API_KEY=            # https://deepgram.com — word-тайминги для субтитров

# ── ПРЯМАЯ ПУБЛИКАЦИЯ (social_publisher) ───────────────────────────────
MEDIA_BUCKET=media           # Supabase Storage bucket для presigned upload

# ── ТРЕКИНГ (Keitaro) ──────────────────────────────────────────────────
KEITARO_API_KEY=
KEITARO_DOMAIN=

# ── ОЗВУЧКА A35 TTS / СУБТИТРЫ A34 ─────────────────────────────────────
ELEVENLABS_API_KEY=          # fallback-провайдер TTS
ELEVENLABS_VOICE_ID=         # id голоса ElevenLabs (по умолчанию 'default')
TTS_SERVER_URL=              # приоритетный self-hosted TTS (Kokoro/Chatterbox), возвращает audio/*
# субтитры A34 берут word-тайминги из DEEPGRAM_API_KEY (см. блок транскрипции)

# ── LITELLM ROUTER + BUDGET GUARD ──────────────────────────────────────
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=
LITELLM_DAILY_BUDGET=20.0     # дневной лимит расхода, USD

# ── OBSIDIAN VAULT (A24 база знаний) ───────────────────────────────────
OBSIDIAN_VAULT_PATH=/opt/ubt-os/obsidian-vault
OBSIDIAN_REMOTE_URL=          # git remote для синхронизации vault
OBSIDIAN_BRANCH=main

# ── A28 ПРОГРЕВ ─────────────────────────────────────────────────────────
WARMUP_STATE_FILE=/var/lib/ubt_os/warmup_state.json

# ── АЛЕРТЫ В TELEGRAM ──────────────────────────────────────────────────
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── ЛОГИРОВАНИЕ ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text

# ── ВНЕШНИЕ ВОРКЕРЫ (опционально) ──────────────────────────────────────
TIKTOK_UPLOADER_URL=

# ── DOCKER COMPOSE (локальные Postgres/Redis) ──────────────────────────
POSTGRES_PASSWORD=
REDIS_PASSWORD=
