# UBT OS Dashboard — переменные окружения (Vite)
# Скопируй в .env и заполни:  cp .env.example .env
# Все переменные ДОЛЖНЫ начинаться с VITE_ — иначе Vite их не пробросит в клиент.

# ── Agents API ──────────────────────────────────────────────
# Базовый URL агентского сервера. Примеры:
#   http://88.218.121.108:8080   — прямой доступ по порту
#   http://88.218.121.108        — за nginx без порта
#   (пустая строка)              — same-origin (запросы на тот же хост, что и дашборд)
VITE_AGENTS_SERVER=http://88.218.121.108:8080

# ── n8n ─────────────────────────────────────────────────────
VITE_N8N_URL=http://88.218.121.108:5678

# ── Supabase (публичные значения, anon-ключ) ────────────────
VITE_SUPABASE_URL=https://ricuoztdelapexfpqsux.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
